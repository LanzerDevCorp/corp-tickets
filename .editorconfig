# Universal editor baseline — honored by VSCode (+forks), JetBrains, Zed, Neovim, etc.
# Keep aligned with prettier.config.mjs
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown: two trailing spaces are a hard line break — don't strip them
[*.md]
trim_trailing_whitespace = false
