# Supabase (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (https://resend.com/api-keys)
# Resend transactional email API key -- required for email delivery
RESEND_API_KEY=
# Verified sender address used in all outgoing emails (must be a Resend-verified domain)
RESEND_FROM_EMAIL=

# Cloudflare Turnstile (https://dash.cloudflare.com/turnstile)
# For local dev / CI use the official Cloudflare test keys (always pass):
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# See: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# App
NEXT_PUBLIC_SITE_URL=
