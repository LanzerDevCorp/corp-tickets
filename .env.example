# Supabase (https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (https://resend.com/api-keys)
# Resend transactional email API key -- required for email delivery
RESEND_API_KEY=
# Verified sender address used in all outgoing emails (must be a Resend-verified domain)
RESEND_FROM_EMAIL=

# Cloudflare Turnstile — DISABLED (see docs/technical-debt.md)
# To re-enable: set TURNSTILE_ENABLED=true in lib/turnstile/config.ts and configure:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Test keys always pass — https://developers.cloudflare.com/turnstile/troubleshooting/testing/

# App
NEXT_PUBLIC_SITE_URL=
# Optional: dedicated HMAC secret for reusable client ticket links (defaults to SUPABASE_SERVICE_ROLE_KEY)
TICKET_ACCESS_SECRET=
